{
  "name": "get-anything-done",
  "version": "1.32.0",
  "description": "A meta-prompting, context engineering and spec-driven development system for Claude Code, OpenCode, Gemini and Codex by MagicbornStudios.",
  "bin": {
    "get-anything-done": "bin/install.js",
    "gad": "bin/gad.cjs",
    "gad-tools": "bin/gad-tools.cjs"
  },
  "files": [
    "bin",
    "commands",
    "dist",
    "agents",
    "hooks/dist",
    "lib",
    "references",
    "skills",
    "templates",
    "workflows",
    "scripts"
  ],
  "keywords": [
    "claude",
    "claude-code",
    "ai",
    "meta-prompting",
    "context-engineering",
    "spec-driven-development",
    "gemini",
    "gemini-cli",
    "codex",
    "codex-cli"
  ],
  "author": "MagicbornStudios",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MagicbornStudios/get-anything-done.git"
  },
  "homepage": "https://github.com/MagicbornStudios/get-anything-done",
  "bugs": {
    "url": "https://github.com/MagicbornStudios/get-anything-done/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "citty": "^0.1.6"
  },
  "devDependencies": {
    "c8": "^11.0.0",
    "esbuild": "^0.24.0",
    "postject": "^1.0.0-alpha.6",
    "vitest": "^4.1.2"
  },
  "scripts": {
    "audit:portability": "node scripts/audit-portability.mjs",
    "build:skills": "node scripts/sync-canonical-skills.mjs",
    "build:cli": "node scripts/build-cli.mjs",
    "build:hooks": "node scripts/build-hooks.js",
    "build:release-support": "node scripts/build-release-support.mjs",
    "build:release": "node scripts/build-release.mjs",
    "publish:release": "node scripts/publish-release.mjs",
    "release:check": "node scripts/release-should-build.mjs",
    "prepublishOnly": "npm run build:hooks && npm run build:cli",
    "test": "node scripts/run-tests.cjs",
    "test:coverage": "c8 --check-coverage --lines 70 --reporter text --exclude 'tests/**' --all node scripts/run-tests.cjs"
  }
}
