{
  "name": "get-anything-done",
  "version": "1.32.0",
  "description": "A meta-prompting, context engineering and spec-driven development system for Claude Code, OpenCode, Gemini and Codex by MagicbornStudios.",
  "bin": {
    "get-anything-done": "bin/install.js",
    "gad": "bin/gad.cjs"
  },
  "files": [
    "bin",
    "commands",
    "get-shit-done",
    "agents",
    "hooks/dist",
    "scripts"
  ],
  "keywords": [
    "claude",
    "claude-code",
    "ai",
    "meta-prompting",
    "context-engineering",
    "spec-driven-development",
    "gemini",
    "gemini-cli",
    "codex",
    "codex-cli"
  ],
  "author": "MagicbornStudios",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MagicbornStudios/get-anything-done.git"
  },
  "homepage": "https://github.com/MagicbornStudios/get-anything-done",
  "bugs": {
    "url": "https://github.com/MagicbornStudios/get-anything-done/issues"
  },
  "peerDependencies": {
    "get-shit-done-cc": ">=1.30.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "citty": "^0.1.6"
  },
  "devDependencies": {
    "c8": "^11.0.0",
    "esbuild": "^0.24.0",
    "vitest": "^4.1.2"
  },
  "scripts": {
    "build:hooks": "node scripts/build-hooks.js",
    "prepublishOnly": "npm run build:hooks",
    "test": "node scripts/run-tests.cjs",
    "test:coverage": "c8 --check-coverage --lines 70 --reporter text --include 'get-shit-done/bin/lib/*.cjs' --exclude 'tests/**' --all node scripts/run-tests.cjs"
  }
}
