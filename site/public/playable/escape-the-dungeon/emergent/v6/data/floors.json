              { "id": "shop_ward_ring", "name": "Ward Ring", "type": "equipment", "icon": "game-icons:ring", "cost": 20, "slot": "accessory", "stats": { "defense": 2, "maxHp": 10 } },
              { "id": "shop_mana_crystal", "name": "Mana Crystal", "type": "consumable", "icon": "game-icons:crystal-ball", "cost": 12, "effect": { "mana": 30 } },
              { "id": "shop_rune_shadow", "name": "Shadow Rune", "type": "rune", "icon": "game-icons:eclipse-flare", "cost": 25, "element": "shadow" }
            ]
