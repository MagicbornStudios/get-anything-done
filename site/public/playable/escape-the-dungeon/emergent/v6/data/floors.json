    {
      "id": "f2",
      "name": "The Mirror Halls",
      "theme": "crystal",
      "pressureNote": "Enemies here REFLECT direct damage back at you. Use indirect effects (DoT, bypass) or you'll destroy yourself. Mana-draining enemies add pressure.",
      "rooms": [
        {
          "id": "f2_entry",
          "name": "Crystal Vestibule",
          "type": "entrance",
          "icon": "game-icons:crystal-growth",
