        {
          "id": "f2_dialogue1",
          "name": "The Mirror Oracle",
          "type": "dialogue",
          "icon": "game-icons:mirror-mirror",
          "description": "A figure that looks exactly like you stands in the mirror, but its expression is wrong -- colder, more calculating.",
          "exits": ["f2_corridor1", "f2_combat2"],
          "npc": {
            "name": "Your Reflection",
            "icon": "game-icons:mirror-mirror",
            "greeting": "We meet at last, real one. I know what you fear. I know what you desire. Shall we trade truths?",
            "branches": [
              {
                "text": "Tell me how to defeat the Mirror Wraith.",
                "traitShift": { "cunning": 0.1 },
                "response": "The Wraith reflects everything you throw at it. Only damage that seeps in slowly -- poisons, burns, hexes -- can harm it. The forge can make such spells if you combine shadow and nature runes.",
                "reward": { "type": "xp", "value": 15 }
              },
              {
                "text": "I don't trust reflections. Show me what's real.",
                "traitShift": { "aggression": 0.1, "cunning": -0.05 },
                "response": "Reality? Reality is that you're running out of mana and time. But fine -- here's something real enough. Gold, from a dead adventurer's pocket.",
                "reward": { "type": "gold", "value": 20 }
              },
              {
                "text": "I feel sorry for you, trapped in glass forever.",
                "traitShift": { "compassion": 0.15, "aggression": -0.05 },
                "response": "Compassion... I had forgotten what that felt like. Take this healing energy -- you'll need it more than I will.",
                "reward": { "type": "hp", "value": 30 }
              }
            ]
          }
        },
        {
