        {
          "id": "f1_dialogue1",
          "name": "Imprisoned Spirit",
          "type": "dialogue",
          "icon": "game-icons:ghost",
          "description": "A translucent figure hovers behind ancient bars, its eyes flickering with spectral light.",
          "exits": ["f1_corridor1", "f1_combat2"],
          "npc": {
            "name": "Elara's Shade",
            "icon": "game-icons:ghost",
            "greeting": "You... you can see me? I've been trapped here for centuries. Will you hear my plea, or are you just another looter?",
            "branches": [
              {
                "text": "I'll help you. What do you need?",
                "traitShift": { "compassion": 0.1, "aggression": -0.05 },
                "response": "Bless you. Take this rune I've guarded. You'll need it against the shadow creatures below. Combine it with blood at the forge.",
                "reward": { "type": "rune", "value": "rune_shadow" }
              },
              {
                "text": "What's in it for me?",
                "traitShift": { "cunning": 0.1, "compassion": -0.05 },
                "response": "A mercenary's heart. Fine -- I have knowledge. The boss of this floor resists direct spells. Only damage-over-time effects can hurt it properly. Here's some gold for your trouble.",
                "reward": { "type": "gold", "value": 15 }
              },
              {
                "text": "Out of my way, ghost.",
                "traitShift": { "aggression": 0.15, "compassion": -0.1 },
                "response": "Such cruelty... You remind me of the one who trapped me. Go then, and face the dungeon with nothing but your rage.",
                "reward": null
              }
            ]
          }
        },
