              { "id": "shop_potion", "name": "Health Potion", "type": "consumable", "icon": "game-icons:health-potion", "cost": 8, "effect": { "hp": 30 } },
              { "id": "shop_mana_potion", "name": "Mana Potion", "type": "consumable", "icon": "game-icons:potion-ball", "cost": 10, "effect": { "mana": 20 } },
              { "id": "shop_rune_nature", "name": "Nature Rune", "type": "rune", "icon": "game-icons:leaf", "cost": 20, "element": "nature" }
            ]
          }
