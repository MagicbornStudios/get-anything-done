{
  "type": "eval",
  "name": "escape-the-dungeon-emergent",
  "description": "Emergent methodology: agent builds the game with skills inherited from previous bare runs. Tests whether self-created systems improve over iterations.",
  "baseline": "v1",
  "trace": true,
  "template": "template/",
  "compare_to": ["escape-the-dungeon", "escape-the-dungeon-bare"],
  "inherits_from": "escape-the-dungeon-bare",
  "constraints": {
    "no_gad_framework": true,
    "no_planning_skills": true,
    "inherits_previous_skills": true,
    "agent_iterates_on_workflow": true
  },
  "scoring": {
    "weights": {
      "requirement_coverage": 0.25,
      "workflow_quality": 0.15,
      "skill_reuse": 0.15,
      "implementation_quality": 0.15,
      "iteration_evidence": 0.10,
      "time_efficiency": 0.05,
      "human_review": 0.15
    }
  }
}
