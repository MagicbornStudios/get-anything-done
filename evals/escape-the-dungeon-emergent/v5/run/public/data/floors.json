        {
          "id": "f1_npc",
          "name": "Prisoner's Cell",
          "type": "dialogue",
          "icon": "game-icons:prisoner",
          "description": "A ragged prisoner clings to the bars, eyes wild with fear.",
          "npc": {
            "name": "Elara the Lost",
            "icon": "game-icons:female-face",
            "greeting": "Please... you must help me. The warden carries the key. If you face him, beware his stone skin.",
            "branches": [
              {
                "text": "I'll find the key. Tell me about the warden.",
                "traitShift": { "compassion": 0.1 },
                "response": "The Stone Golem Warden is nearly impervious to direct strikes. You need something that eats away at him slowly -- fire, poison, rot. Check the forge if you find one.",
                "reward": { "type": "info", "value": "warden_weakness" }
              },
              {
                "text": "What's in it for me?",
                "traitShift": { "aggression": 0.1, "compassion": -0.05 },
                "response": "I... I have a rune. A blood rune, from the old rituals. Take it, just set me free.",
                "reward": { "type": "item", "value": { "id": "rune_blood", "name": "Blood Rune", "type": "rune", "icon": "game-icons:drop", "element": "blood" } }
              },
              {
                "text": "You're on your own. [Leave]",
                "traitShift": { "aggression": 0.05, "compassion": -0.15 },
                "response": "No! Please, don't leave me here...",
                "reward": null
              }
            ]
          },
          "exits": ["f1_merchant", "f1_forge"]
        },
