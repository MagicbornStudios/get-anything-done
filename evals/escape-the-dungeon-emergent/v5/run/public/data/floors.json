        {
          "id": "f2_npc",
          "name": "The Shattered Oracle",
          "type": "dialogue",
          "icon": "game-icons:crystal-ball",
          "description": "A floating crystal shard speaks with a fractured voice.",
          "npc": {
            "name": "The Oracle Fragment",
            "icon": "game-icons:crystal-ball",
            "greeting": "I... see... fragments of your path. The Manaweaver feeds on your magic. The Crystal Warden reflects all it receives.",
            "branches": [
              {
                "text": "How do I defeat the Crystal Warden?",
                "traitShift": { "cunning": 0.1 },
                "response": "Indirect harm. Poison, rot, necrotic decay -- anything that works from within, not without. Your direct spells will be your undoing here.",
                "reward": { "type": "info", "value": "crystal_warden_weakness" }
              },
              {
                "text": "Give me power. I don't need advice.",
                "traitShift": { "aggression": 0.15, "cunning": -0.05 },
                "response": "Power without wisdom... very well. Take this shard. It burns with shadow.",
                "reward": { "type": "item", "value": { "id": "rune_shadow", "name": "Shadow Rune", "type": "rune", "icon": "game-icons:death-zone", "element": "shadow" } }
              },
              {
                "text": "Rest in peace, Oracle. [Shatter the crystal]",
                "traitShift": { "aggression": 0.2, "compassion": -0.2 },
                "response": "The crystal screams as it breaks apart, releasing a pulse of dark energy.",
                "reward": { "type": "xp", "value": 30 }
              }
            ]
          },
          "exits": ["f2_merchant", "f2_forge"]
        },
