in(phaseDir, '01-01-SUMMARY.md'), summaryContent);\r\n\r\n    const result = runGsdTools('history-digest', tmpDir);\r\n    assert.ok(result.success, `Command failed: ${result.error}`);\r\n\r\n    const digest = JSON.parse(result.output);\r\n"}
