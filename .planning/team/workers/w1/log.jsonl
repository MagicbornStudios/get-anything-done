md'),\r\n      '# Project State\\n\\n## Current Position\\n\\nPhase: 1 of 1 (Test)\\n'\r\n    );\r\n    const result = runGsdTools(`--cwd=${tmpDir} state load`, process.cwd());\r\n    assert.st"}
